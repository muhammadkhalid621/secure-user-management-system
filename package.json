{
  "name": "mini-secure-user-management-system",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend & npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "db:migrate": "npm run db:migrate --workspace backend",
    "db:migrate:undo": "npm run db:migrate:undo --workspace backend",
    "db:seed": "npm run db:seed --workspace backend",
    "db:seed:undo": "npm run db:seed:undo --workspace backend",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  }
}
