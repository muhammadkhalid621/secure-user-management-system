NODE_ENV=development
PORT=4000
APP_NAME=Mini Secure User Management API
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://sums_user:sums_password@localhost:5432/sums_db
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10
WS_ORIGIN=http://localhost:3000

