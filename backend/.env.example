NODE_ENV=development
PORT=4000
APP_NAME=Mini Secure User Management API
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
JWT_ACCESS_SECRET=replace_with_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
PAGINATION_DEFAULT_PAGE=1
PAGINATION_DEFAULT_LIMIT=10
PAGINATION_MAX_LIMIT=100
WS_ORIGIN=http://localhost:3000

# MySQL database
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sums_db
DB_USER=sums_user
DB_PASSWORD=sums_password
DB_ROOT_PASSWORD=root_password
DB_LOGGING=false
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
DATABASE_URL=mysql://sums_user:sums_password@127.0.0.1:3306/sums_db

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://127.0.0.1:6379

# Bull queue
BULL_PREFIX=sums
BULL_AUTH_QUEUE=auth
BULL_NOTIFICATIONS_QUEUE=notifications
BULL_CONNECTION_NAME=sums-bull
BULL_DEFAULT_JOB_ATTEMPTS=3
BULL_DEFAULT_JOB_BACKOFF_MS=1000

# Cache
CACHE_TTL_SECONDS=60
CACHE_USERS_TTL_SECONDS=120
CACHE_AUTH_PROFILE_TTL_SECONDS=60

# Socket
SOCKET_CORS_ORIGIN=http://localhost:3000
SOCKET_NOTIFICATION_EVENT=notification
SOCKET_AUTH_REQUIRED=true

# Sequelize CLI
SEQUELIZE_CLI_MIGRATIONS_PATH=database/migrations
SEQUELIZE_CLI_SEEDERS_PATH=database/seeders
